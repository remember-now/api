{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build:*)",
      "Bash(npm run format)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(git diff:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(xargs:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(npm ls:*)",
      "Bash(npm list:*)",
      "Bash(npx tsc:*)",
      "Bash(npx install:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "mcp__ide__getDiagnostics",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": ["Read(./.env)", "Read(~/.aws/**)"]
  },
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
