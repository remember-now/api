// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// NOTE: Useful v7 migration info
// https://www.prisma.io/docs/orm/more/upgrade-guides/upgrading-versions/upgrading-to-prisma-7

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN

  @@map("role")
}

enum LlmProvider {
  ANTHROPIC
  GOOGLE_GEMINI
  PLATFORM

  @@map("llm_provider")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  email        String @unique
  passwordHash String @map("password_hash")

  activeLlmProvider LlmProvider? @map("active_llm_provider")
  llmConfigs        LlmConfig[]
  graphs            Graph[]

  @@map("users")
}

model Graph {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityNodes     EntityNode[]
  entityEdges     EntityEdge[]
  episodicNodes   EpisodicNode[]
  episodicEdges   EpisodicEdge[]
  sagaNodes       SagaNode[]
  hasEpisodeEdges HasEpisodeEdge[]

  @@unique([userId, name])
  @@index([userId])
  @@map("graphs")
}

model LlmConfig {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  provider  LlmProvider
  config    Json
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("llm_configs")
}

// ─── Knowledge Graph ──────────────────────────────────────────────────────────
// Postgres-backed replacement for the old Neo4j layer.
// all vector I/O goes through $queryRaw / $executeRaw with ::vector casts
// See migrations/20260517000000_knowledge_graph/migration.sql for:
// vectorscale extension, graph_label_for fn, graph_label SMALLINT[] column +
// trigger, diskann + GIN indexes.

model EntityNode {
  id            String                      @id @db.Uuid
  graphId       String                      @map("graph_id") @db.Uuid
  name          String
  summary       String                      @default("")
  attributes    Json                        @default("{}")
  labels        String[]
  nameEmbedding Unsupported("vector(768)")? @map("name_embedding")
  // Populated by a BEFORE INSERT/UPDATE trigger from graph_id - see migration SQL.
  // Declared here so Prisma's shadow-DB diff sees the column. Never written by app code.
  graphLabel    Int[]                       @map("graph_label") @db.SmallInt
  createdAt     DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)

  graph       Graph          @relation(fields: [graphId], references: [id], onDelete: Cascade)
  sourceEdges EntityEdge[]   @relation("EntityEdgeSource")
  targetEdges EntityEdge[]   @relation("EntityEdgeTarget")
  mentions    EpisodicEdge[]

  @@index([graphId])
  // Declared so Prisma's diff sees the index by name and stops proposing a drop.
  // Actual index is created as `USING diskann (name_embedding vector_cosine_ops, graph_label)` in the migration.
  @@index([nameEmbedding, graphLabel], map: "entity_nodes_embedding_idx")
  @@map("entity_nodes")
}

model EntityEdge {
  id            String                      @id @db.Uuid
  graphId       String                      @map("graph_id") @db.Uuid
  sourceId      String                      @map("source_id") @db.Uuid
  targetId      String                      @map("target_id") @db.Uuid
  name          String
  fact          String
  factEmbedding Unsupported("vector(768)")? @map("fact_embedding")
  // Populated by a BEFORE INSERT/UPDATE trigger from graph_id - see migration SQL.
  graphLabel    Int[]                       @map("graph_label") @db.SmallInt
  attributes    Json                        @default("{}")
  episodes      String[]                    @db.Uuid
  validAt       DateTime?                   @map("valid_at") @db.Timestamptz(3)
  invalidAt     DateTime?                   @map("invalid_at") @db.Timestamptz(3)
  expiredAt     DateTime?                   @map("expired_at") @db.Timestamptz(3)
  createdAt     DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)

  graph      Graph      @relation(fields: [graphId], references: [id], onDelete: Cascade)
  sourceNode EntityNode @relation("EntityEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetNode EntityNode @relation("EntityEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@index([sourceId])
  @@index([targetId])
  // See EntityNode for rationale
  @@index([factEmbedding, graphLabel], map: "entity_edges_embedding_idx")
  @@map("entity_edges")
}

model EpisodicNode {
  id                String   @id @db.Uuid
  graphId           String   @map("graph_id") @db.Uuid
  name              String
  labels            String[]
  source            String
  sourceDescription String   @map("source_description")
  content           String
  validAt           DateTime @map("valid_at") @db.Timestamptz(3)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  graph           Graph            @relation(fields: [graphId], references: [id], onDelete: Cascade)
  mentions        EpisodicEdge[]
  hasEpisodeEdges HasEpisodeEdge[]

  @@index([graphId])
  @@index([validAt])
  @@map("episodic_nodes")
}

model EpisodicEdge {
  id         String   @id @db.Uuid
  graphId    String   @map("graph_id") @db.Uuid
  episodicId String   @map("episodic_id") @db.Uuid
  entityId   String   @map("entity_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  graph   Graph        @relation(fields: [graphId], references: [id], onDelete: Cascade)
  episode EpisodicNode @relation(fields: [episodicId], references: [id], onDelete: Cascade)
  entity  EntityNode   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@index([episodicId])
  @@index([entityId])
  @@map("episodic_edges")
}

model SagaNode {
  id               String    @id @db.Uuid
  graphId          String    @map("graph_id") @db.Uuid
  name             String
  labels           String[]
  summary          String    @default("")
  lastSummarizedAt DateTime? @map("last_summarized_at") @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  graph           Graph            @relation(fields: [graphId], references: [id], onDelete: Cascade)
  hasEpisodeEdges HasEpisodeEdge[]

  @@index([graphId])
  @@index([name])
  @@map("saga_nodes")
}

model HasEpisodeEdge {
  id         String   @id @db.Uuid
  graphId    String   @map("graph_id") @db.Uuid
  sagaId     String   @map("saga_id") @db.Uuid
  episodicId String   @map("episodic_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  graph   Graph        @relation(fields: [graphId], references: [id], onDelete: Cascade)
  saga    SagaNode     @relation(fields: [sagaId], references: [id], onDelete: Cascade)
  episode EpisodicNode @relation(fields: [episodicId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@index([sagaId])
  @@map("has_episode_edges")
}
