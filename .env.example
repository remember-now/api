# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASS=changeme

POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASS}@${POSTGRES_HOST}:${POSTGRES_PORT}/postgres
# Postgres image is timescale/timescaledb-ha:pg17 (bundles pgvector + pgvectorscale)

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=changeme
REDIS_URL=redis://:${REDIS_PASS}@${REDIS_HOST}:${REDIS_PORT}

# App
APP_PORT=3333
APP_FRONTEND_URL=http://localhost:5173
APP_SESSION_SECRET=changeme
APP_SESSION_EXPIRY_HOURS=336 # 2 weeks
APP_LOG_LEVEL=info # one of: trace, debug, info, warn, error, fatal

# App:Crypto
ENCRYPTION_KEY= # 64-char hex string (32 bytes), generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# App:LLM
PLATFORM_MODEL_ENABLED=false
GEMINI_API_KEY=
LLM_PLATFORM_MODEL=gemini-3.0-flash

# App:Embedding
EMBEDDING_ENABLED=false
GOOGLE_EMBEDDING_API_KEY=
GOOGLE_EMBEDDING_MODEL=gemini-embedding-2
# NOTE: This env var is read at runtime, but the Postgres vector column width
# is fixed by the knowledge-graph migration (vector(768) on entity_nodes /
# entity_edges). Changing this number alone will fail at insert time - you
# must also update the schema + migration to a matching vector(N) and re-deploy.
GOOGLE_EMBEDDING_DIMENSIONS=768

# App:Observability
# LANGFUSE_ENABLED=true requires this to be true (error at boot otherwise).
TELEMETRY_ENABLED=false
OTEL_CONSOLE_EXPORT_ENABLED=false # every completed OTel span is printed to stdout.

# App:Observability (Langfuse) - dev only. See README "Langfuse observability".
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3334
